              "});",
              "if (pm.response.code === 200) {",
              "  pm.test('Dados do usuário são os esperados', function () {",
              "    pm.expect(jsonData.nome).to.eql(pm.environment.get('usuarioNome'));",
              "    pm.expect(jsonData.email).to.eql(pm.environment.get('usuarioEmail'));",
              "    pm.expect(jsonData.password).to.eql(pm.environment.get('usuarioPassword'));",
              "  });",
              "}"
            ]
          }
        }
      ]
