{
  "info": {
    "name": "ServeRest Usuários",
    "_postman_id": "sererest-usuarios-collection",
    "description": "Collection para testes dos endpoints de usuários da API ServeRest, com scripts para salvar token e id do usuário.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1 - Login Sucesso",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"fulano@qa.com\",\n  \"password\": \"teste\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": ["{{baseUrl}}"],
          "path": ["login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Valida status code",
              "pm.test('Status code esperado', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "});",
              "// Valida headers",
              "pm.test('Header Content-Type é application/json', function () {",
              "  pm.response.to.have.header('Content-Type');",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "// Valida contrato da resposta com Ajv",
              "const schema = {",
              "  type: 'object',",
              "  properties: {",
              "    message: { type: 'string' },",
              "    authorization: { type: 'string' }",
              "  },",
              "  required: ['message', 'authorization']",
              "};",
              "const Ajv = require('ajv');",
              "const ajv = new Ajv();",
              "const validate = ajv.compile(schema);",
              "const jsonData = pm.response.json();",
              "pm.test('Contrato da resposta está válido', function () {",
              "  pm.expect(validate(jsonData)).to.be.true;",
              "});",
              "pm.environment.set('token', jsonData.authorization);"
            ]
          }
        }
      ]
    },
