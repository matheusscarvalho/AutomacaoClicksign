    {
      "name": "3 - Cadastrar Usuário",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"{{nome}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"administrador\": \"true\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/usuarios",
          "host": ["{{baseUrl}}"],
          "path": ["usuarios"]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Gerar dados dinâmicos do usuário",
              "const random = Math.floor(Math.random() * 100000);",
              "pm.variables.set('nome', `Fulano${random}`);",
              "pm.variables.set('email', `fulano${random}@qa.com.br`);",
              "pm.variables.set('password', `senha${random}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Valida status code",
              "pm.test('Status code esperado', function () {",
              "  pm.expect(pm.response.code).to.eql(201);",
              "});",
              "// Valida headers",
              "pm.test('Header Content-Type é application/json', function () {",
              "  pm.response.to.have.header('Content-Type');",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "// Valida contrato da resposta com Ajv",
              "const Ajv = require('ajv');",
              "const ajv = new Ajv();",
              "let schema;",
              "if (pm.response.code === 201) {",
              "  schema = {",
              "    type: 'object',",
              "    properties: {",
              "      message: { type: 'string' },",
              "      _id: { type: 'string' }",
              "    },",
              "    required: ['message', '_id']",
              "  };",
              "} else if (pm.response.code === 400) {",
              "  schema = {",
              "    type: 'object',",
              "    properties: {",
              "      message: { type: 'string' }",
              "    },",
              "    required: ['message']",
              "  };",
              "}",
              "const validate = ajv.compile(schema);",
              "const jsonData = pm.response.json();",
              "pm.test('Contrato da resposta está válido', function () {",
              "  pm.expect(validate(jsonData)).to.be.true;",
              "});",
              "if (pm.response.code === 201) {",
              "  pm.environment.set('usuarioId', jsonData._id);",
              "  pm.environment.set('usuarioNome', pm.variables.get('nome'));",
              "  pm.environment.set('usuarioEmail', pm.variables.get('email'));",
              "  pm.environment.set('usuarioPassword', pm.variables.get('password'));",
              "}"
            ]
          }
        }
      ]
    },
