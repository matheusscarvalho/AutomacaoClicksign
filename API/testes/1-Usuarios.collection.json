              "      administrador: { type: 'string' },",
              "      _id: { type: 'string' }",
              "    },",
              "    required: ['nome', 'email', 'password', 'administrador', '_id']",
              "  };",
              "} else if (pm.response.code === 400) {",
              "  schema = {",
              "    type: 'object',",
              "    properties: {",
              "      message: { type: 'string' }",
              "    },",
              "    required: ['message']",
              "  };",
              "}",
              "const validate = ajv.compile(schema);",
